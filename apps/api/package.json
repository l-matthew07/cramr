{
  "name": "@cramr/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "cd ../packages/db && npx prisma generate && npx prisma db push --accept-data-loss && cd ../../api && node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@clerk/clerk-sdk-node": "^5.0.30",
    "@cramr/db": "workspace:*",
    "@cramr/shared": "workspace:*",
    "@prisma/client": "^5.14.0",
    "@sentry/node": "^10.49.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ioredis": "^5.4.1",
    "resend": "^6.12.0",
    "socket.io": "^4.7.5",
    "svix": "^1.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.12",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^2.1.9",
    "supertest": "^7.2.2",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5",
    "vitest": "^2.1.9"
  }
}
